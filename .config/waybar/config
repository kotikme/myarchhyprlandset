{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces", "custom/language"],
    "modules-center": [],
    "modules-right": ["cpu", "memory", "disk", "temperature", "backlight", "battery", "pulseaudio", "network", "clock"],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },

    "custom/language": {
        "format": "{}",
        "exec": "hyprctl devices -j | jq -r '.keyboards[] | select(.main == true) | .active_keymap' | cut -c1-2 | tr 'a-z' 'A-Z'",
        "interval": 1,
        "tooltip": false
    },

    "cpu": {
        "format": "CPU {usage}%",
        "interval": 2,
        "tooltip": true
    },

    "memory": {
        "format": "RAM {}%",
        "interval": 5,
        "tooltip": true
    },

    "disk": {
        "format": "{free} GB",
        "interval": 30,
        "path": "/",
        "tooltip": true
    },

    "temperature": {
        "format": "🌡️ {temperatureC}°C",
        "interval": 5,
        "critical-threshold": 75,
        "tooltip": true
    },

    "backlight": {
        "format": "☀️ {percent}%",
        "interval": 2,
        "tooltip": true
    },

    "battery": {
        "format": "🔋 {capacity}%",
        "format-charging": "⚡ {capacity}%",
        "format-full": "✅ {capacity}%",
        "interval": 30,
        "tooltip": true
    },

    "pulseaudio": {
        "format": "🔊 {volume}%",
        "format-muted": "🔇 MUTE",
        "on-click": "pavucontrol",
        "tooltip": true
    },

    "network": {
        "format": "📶 {essid}",
        "format-disconnected": "❌ Offline",
        "tooltip-format": "{ifname} {ipaddr}",
        "interval": 5
    },

    "clock": {
        "format": "🕐 {:%H:%M}",
        "interval": 60,
        "tooltip": true
    }
}